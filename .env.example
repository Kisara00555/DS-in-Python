# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── OPTIONAL (defaults shown) ─────────────────────────────────────────────────
# LLM used for answer generation and query expansion
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.0

# Embedding model:
#   Local (default): all-MiniLM-L6-v2  — offline, no quota, 384-dim
#   Cloud (legacy):  gemini-embedding-2 — requires GOOGLE_API_KEY, subject to quota
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Vector store (ChromaDB on disk)
VECTOR_STORE_PATH=./data/vector_store
COLLECTION_NAME=ai_funding_corpus

# Retrieval
TOP_K=5

# Paths
DATA_DIR=./data/pdfs
EVAL_DATASET_PATH=./data/evaluation/ground_truth.json
EVAL_RESULTS_PATH=./data/evaluation/results.json
